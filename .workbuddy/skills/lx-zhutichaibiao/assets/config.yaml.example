# lx-zhutichaibiao 旧配置模板
# 新用户不要复制本文件；请填写项目根目录 config/fog_config.yaml 的 lx_zhutichaibiao 段。
# 本文件仅用于兼容未迁移的旧本地配置。

# ---- 项目配置 ----
# 项目根目录：工作空间的根路径（绝对路径）
项目根目录: ""  # 留空则在脚本运行时自动使用当前目录

# 码表来源：固定从 lx_shujuku 查询公司 dataReporting.operator_brand
# 请先在 config/fog_config.yaml 中配置 lx_shujuku.api
码表来源: "lx_shujuku.operator_brand"

# 默认对接人列表（按团队实际情况修改）
默认对接人:
  - 雷维亮

# 工作目录：包含 输入/、输出/、原表存档/ 三个子目录
# 推荐使用相对于项目根目录的路径，便于多人共享
工作目录: "workspace/01主体拆表"

# ---- 默认规则 ----
默认:
  # 城市字段候选列表
  城市字段:
    - 城市
    - 城市名称
    - 注册城市
    - 所属城市
    - 所属城市名称
    - 城市名
    - city_name

  # 品牌字段候选列表
  品牌字段:
    - 品牌
    - 品牌名称
    - 商家
    - 商家名称
    - 合作品牌
    - 合作商家
    - 运力品牌
    - brand_name

  # 处理的 sheet（空=全部）
  处理sheet: []

  # sheet 级别的表头行数（可选）
  # 表头行数: {}

# ---- 特定文件配置（按文件名关键词匹配） ----
# 示例：
# 特定配置:
#   - 匹配: "沉默人群活动"
#     保留 sheet:
#       - 沉默策略活动
#       - 策略汇总
#     品牌字段:
#       - 品牌名称
#     城市字段:
#       - 注册城市
#       - 城市
#   - 匹配: "司机明细"
#     品牌字段:
#       - 品牌名称
#     城市字段:
#       - 注册城市
#     处理sheet:
#       - 汇总1
#       - 司机明细
特定配置: []
