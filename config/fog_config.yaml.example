# FOG 项目统一配置模板
# 复制为 config/fog_config.yaml 后填写个人配置。
# config/fog_config.yaml 包含账号、token、个人目录等敏感或本地化信息，不提交到版本控制。
# 不分享给同事的内部 Skill 配置继续放在 config/personal_config.yaml。

# ============================================================
# version
# 配置模板版本。升级模板时用于判断是否需要迁移。
# ============================================================
version: 1

# ============================================================
# project
# 要配置什么：项目根目录和 workspace 相对目录。
# 从哪里获取：通常 root 留空自动识别；workspace_root 默认 workspace。
# ============================================================
project:
  root: ""
  workspace_root: "workspace"

# ============================================================
# enabled_skills
# 要配置什么：共享给同事的 Skill 开关。
# 说明：内部 Skill 不放在这里，继续使用 personal_config.yaml。
# ============================================================
enabled_skills:
  lx_shujuku: true
  lx_feishudocs: true
  lx_zhutichaibiao: true
  lx_haibao: true
  lx_dapanribao: true
  lx_nongfu: true
  lx_biaogetongbu: true
  lx_celuehuodong: true
  lx_yuedufandian: true

# ============================================================
# database
# 要配置什么：共享能力可选使用的 PostgreSQL 连接信息。
# 说明：没有数据库权限可保持空值；内部写库配置优先放 personal_config.yaml。
# ============================================================
database:
  host: ""
  port: 5432
  database: ""
  user: ""
  password: ""
  sslmode: ""
  connect_timeout: 10

# ============================================================
# lx_yuedufandian
# 要配置什么：月度返点计算默认工作目录、对接人和排除主体。
# 说明：当月具体口径写入 rules.yaml；源 Excel 先入库，本地 PostgreSQL 是默认计算源。
# ============================================================
lx_yuedufandian:
  work_root: "workspace/13月度返点计算"
  default_contacts: []
  exclude_operators:
    - "LX"
  require_rules_yaml: true
  sync_db:
    enabled: false
    require_confirmed: true

# ============================================================
# lx_shujuku
# 要配置什么：dataReporting 查询账号和默认查询限制。
# 从哪里获取：公司 dataReporting 账号；用于 operator_brand 码表和日报数据查询。
# ============================================================
lx_shujuku:
  api:
    base_url: "http://datareporting.sfczhushou.com"
    username: ""
    password: ""
  query:
    default_limit: 100
    max_limit: 1000

# ============================================================
# lx_zhutichaibiao
# 要配置什么：按运营主体拆表的工作目录、默认对接人、字段识别规则。
# 说明：分享模板不写个人默认对接人；本机真实配置可填写中文全名列表。
# ============================================================
lx_zhutichaibiao:
  work_dir: "workspace/01主体拆表"
  default_persons: []
  mabiao_source: "lx_shujuku.operator_brand"
  default:
    city_fields:
      - "城市"
      - "城市名称"
      - "注册城市"
      - "所属城市"
      - "所属城市名称"
      - "城市名"
      - "city_name"
    brand_fields:
      - "品牌"
      - "品牌名称"
      - "商家"
      - "商家名称"
      - "合作品牌"
      - "合作商家"
      - "运力品牌"
      - "brand_name"
    process_sheets: []
  special_configs: []

# ============================================================
# lx_haibao
# 要配置什么：端外海报输出目录和图片生成 API Key。
# 从哪里获取：AIHubMix、火山方舟或 APIMart 控制台。
# ============================================================
lx_haibao:
  output_dir: "workspace/09端外海报图/产出图"
  meta_dir: "workspace/09端外海报图/元数据"
  tmp_dir: "workspace/09端外海报图/临时图"
  image_api:
    providers: ["aihubmix", "apimart", "volcengine_seedream"]
    provider_primary: "aihubmix"
    provider_fallback: "apimart"
    aihubmix:
      api_key: ""
      base_url: "https://aihubmix.com/v1"
      task_base_url: "https://api.aihubmix.com/v1"
      model: "gpt-image-2"
      endpoint: "images_edits"
      quality: "low"
      output_format: "png"
      stream: false
      partial_images: 2
    volcengine_seedream:
      api_key: ""
      base_url: "https://ark.cn-beijing.volces.com/api/v3"
      model: "doubao-seedream-5-0-260128"
      size: "1600x2848"
      response_format: "url"
      output_format: "png"
      watermark: false
    apimart:
      api_key: ""
      base_url: "https://api.apimart.ai/v1"
      model: "gpt-image-2"

# ============================================================
# lx_dapanribao
# 要配置什么：日报输出目录、异常阈值、飞书普通表格发布目标。
# 说明：发布飞书普通表格时依赖 WorkBuddy 飞书连接器和 lx_feishudocs。
# ============================================================
lx_dapanribao:
  default_person: ""
  output_dir: "workspace/03数据报表/日报"
  publish_backend: "lx-feishudocs"
  # 留空时继承 lx_nongfu.operator_doc.contact_person_root_folders.{default_person}
  # 如果日报需要单独放到另一套飞书根目录，再填写下面两个字段之一。
  feishu_root_folder_url: ""
  feishu_root_folder_token: ""
  operator_folder_name_template: "{operator}-运营主体"
  report_title_template: "{operator}-大盘数据日报"
  operator_folder_overrides: {}
  report_title_overrides: {}
  title_suffix: "大盘数据日报"
  anomaly_threshold_volume: 0.05
  anomaly_threshold_rate: 0.02
  deep_analysis_top_k: 5

# ============================================================
# lx_nongfu
# 要配置什么：农夫协作文档拆分、通知和回填同步的默认规则。
# 说明：运营主体人员写入后，回填必须按品牌+城市匹配，不能整表直接覆盖。
# ============================================================
lx_nongfu:
  workspace_dir: "workspace/12农夫协作"
  default_contact_persons: []
  large_doc:
    required_key_columns:
      - "品牌"
      - "城市"
    brand_fields:
      - "品牌"
      - "品牌名称"
      - "商家"
      - "商家名称"
      - "合作品牌"
      - "合作商家"
      - "运力品牌"
      - "brand_name"
    city_fields:
      - "城市"
      - "城市名称"
      - "注册城市"
      - "所属城市"
      - "所属城市名称"
      - "城市名"
      - "city_name"
    header_row: 1
    writeback_update_columns: []
  operator_doc:
    # 大文档链接每次任务输入，不建议写进配置。
    # 这里配置稳定的“对接人 -> 该对接人名下运营主体根文件夹”映射。
    # 共享模板保持空；每位同事在自己的 config/fog_config.yaml 中填写自己的根文件夹。
    contact_person_root_folders: {}
    operator_root_folder_url: ""
    operator_root_folder_token: ""
    operator_folder_name_template: "{operator}-运营主体"
    target_table_name_template: "{operator}-日常信息"
    sheet_name_template: "{date}{topic}"
    feishu_cache_path: ".workbuddy/skills/lx-feishudocs/assets/feishu_sheet_cache.json"
  notification:
    default_audience: "shangjia"
    default_format: "weixin"
  sync:
    require_dry_run: true
    require_brand_city_match: true
    writeback_mode: "update_by_key"

# ============================================================
# lx_biaogetongbu
# 要配置什么：通用表格同步和固定运营主体回填场景。
# 说明：共享模板不写真实飞书大表链接；每个人在本机 config/fog_config.yaml 填自己的默认值。
# ============================================================
lx_biaogetongbu:
  default_contact_persons: []
  operator_sync:
    contact_person_root_folders: {}
    operator_root_folder_url: ""
    operator_root_folder_token: ""
    scenarios:
      beishen_shensu:
        master_url: ""
      jingmo_chengke:
        master_url: ""

# ============================================================
# lx_celuehuodong
# 要配置什么：策略活动表路径、后台导入输出目录、共补原表存档目录、目标城市和免佣卡规则。
# 说明：默认只 dry-run；真实城市、品牌卡券规则可在 config/fog_config.yaml 或 personal_config.yaml 中覆盖。
# ============================================================
lx_celuehuodong:
  strategy_workbook: "workspace/05策略活动/策略活动表/城市策略活动表2604版_v2.xlsm"
  import_output_dir: "workspace/05策略活动/导入后台表格"
  gongbu_archive_dir: "workspace/07共补活动/共补原表存档"
  require_confirmed: true
  target_cities: []
  calendar_cities: []
  cities: {}
  default:
    cards:
      Y:
        name: "大夜免佣卡"
        base_hours: [0, 6]
        subtract_gongbu: true
      A:
        name: "时段免佣卡"
        base_hours: [6, 24]
        subtract_gongbu: true
      S:
        name: "时段免佣卡"
        base_hours: [0, 24]
        subtract_gongbu: true
      K:
        name: "快车单免佣卡"
        base_hours: [0, 24]
        subtract_gongbu: true
        k_only: true
  prices:
    use_excel_prices: true
    sheet_name: "码表-各类型卡单价"
    round_to_point_nine: true
  styles:
    font:
      name: "思源黑体"
      size: 10
    alignment:
      horizontal: "center"
      vertical: "center"
      wrap_text: false
  use_last_row_as_template: true

# ============================================================
# lx_feishudocs
# 要配置什么：飞书普通电子表格后端偏好。
# 说明：账号和 token 由 WorkBuddy 飞书连接器维护，本配置不保存密钥。
# ============================================================
lx_feishudocs:
  cli_path: ""
  identity: "user"
  spreadsheet_type: "sheets"
  default_folder_token: ""
  cache_path: ".workbuddy/skills/lx-feishudocs/assets/feishu_sheet_cache.json"

# init
# 要配置什么：初始化和健康检查行为。
# 说明：共享 Skill 已直接读取 fog_config.yaml，不再生成 per-Skill config.yaml。
# ============================================================
init:
  write_skill_configs: false
  validate_after_write: true
  report_path: ".lx-init-report.md"
